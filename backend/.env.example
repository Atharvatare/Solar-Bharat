# ============================================
# SOLAR BHARAT — Environment Configuration
# ============================================

# Server
NODE_ENV=development
PORT=5000

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/solar-bharat?retryWrites=true&w=majority

# JWT Secrets (CHANGE THESE IN PRODUCTION — min 64 chars)
JWT_SECRET=sb_jwt_secret_2024_change_this_in_production_use_64_chars_minimum_xxxxxxxxxxxxx
JWT_REFRESH_SECRET=sb_refresh_secret_2024_change_this_in_production_use_64_chars_minimum_xxxx
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# File Uploads
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Logging
LOG_LEVEL=debug

# Security
MAX_LOGIN_ATTEMPTS=5
LOCK_DURATION_MS=1800000
SESSION_TIMEOUT_MS=86400000
MAX_ACTIVE_SESSIONS=5
BCRYPT_ROUNDS=12

# Email (SMTP — configure for production)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@solarbharat.com

# App
APP_NAME=Solar Bharat
APP_URL=http://localhost:5000
