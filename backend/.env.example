# ============================================
# SOLAR BHARAT — Environment Configuration
# ============================================

# Server
NODE_ENV=development
PORT=5000

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/solar-bharat?retryWrites=true&w=majority

# JWT Secrets
JWT_SECRET=your_jwt_secret_key_change_this_in_production_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_key_change_this_in_production_min_32_chars
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# File Uploads
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Logging
LOG_LEVEL=debug

# App
APP_NAME=Solar Bharat
APP_URL=http://localhost:5000
